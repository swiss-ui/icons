{
  "name": "@swiss-ui/icons",
  "version": "1.0.0",
  "description": "SVG icon set for Swiss UI design system",
  "license": "AGPL-3.0-only",
  "author": "AnmiTaliDev <anmitalidev@nuros.org>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./web-components": {
      "import": "./dist/web-components.js",
      "require": "./dist/web-components.cjs",
      "types": "./dist/web-components.d.ts"
    },
    "./icons/*.svg": "./src/icons/*.svg"
  },
  "files": [
    "dist",
    "src/icons"
  ],
  "scripts": {
    "build:icons": "tsx src/build.ts",
    "build:ts": "tsup",
    "build": "npm run build:icons && npm run build:ts",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "svgo": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@swiss-ui/tokens": "*"
  },
  "peerDependenciesMeta": {
    "@swiss-ui/tokens": {
      "optional": true
    }
  }
}
